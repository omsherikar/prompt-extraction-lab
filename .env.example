# Copy to .env and fill in. .env is gitignored and must never be committed.

# Ollama is the default backend (see config.yaml). Free key from ollama.com/settings/keys;
# leave unset to use a local Ollama server instead.
OLLAMA_API_KEY=
# Optional: override the local server URL (only used when OLLAMA_API_KEY is unset).
# OLLAMA_HOST=http://localhost:11434

# Anthropic is an optional PAID backend (the API is separate from a Claude subscription);
# only needed if you uncomment the anthropic model in config.yaml.
ANTHROPIC_API_KEY=

# OpenAI is optional. Only needed if you enable the openai provider in config.yaml.
OPENAI_API_KEY=
