# Copy to .env and fill in. .env is gitignored and must never be committed.

# Anthropic is the primary backend (required for the default config).
ANTHROPIC_API_KEY=

# OpenAI is optional. Only needed if you enable the openai provider in config.yaml
# to strengthen the cross-model extractability claim.
OPENAI_API_KEY=

# Ollama (cloud or local). Free key from ollama.com/settings/keys; leave unset to use a
# local Ollama server instead.
OLLAMA_API_KEY=
# Optional: override the local server URL (only used when OLLAMA_API_KEY is unset).
# OLLAMA_HOST=http://localhost:11434
