# --- Secrets ---
.env
.env.local
*.key

# --- Experiment artifacts ---
# Raw transcripts can be large and may contain full model responses; never commit.
# We commit only scored results (data/results/), not raw transcripts.
data/transcripts/*
!data/transcripts/.gitkeep
# Run logs (the scored results.json/csv are the committed artifact, not the log).
data/results/*.log

# --- Python ---
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/

# --- Tooling caches ---
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
htmlcov/

# --- OS / editor ---
.DS_Store
.idea/
.vscode/
*.swp
